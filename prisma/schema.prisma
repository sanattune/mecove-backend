// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  createdAt              DateTime  @default(now())
  role                   String    @default("user")
  approvedAt             DateTime?
  privacyAcceptedAt      DateTime?
  privacyAcceptedVersion String?
  termsAcceptedAt        DateTime?
  termsAcceptedVersion   String?
  mvpAcceptedAt          DateTime?
  mvpAcceptedVersion     String?
  encryptedDek           String?   @db.Text

  identities Identity[]
  messages   Message[]
  summaries  Summary[]
  reminders  UserReminder[]
  settings   UserSettings?
}

model Identity {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  channel        String
  channelUserKey String
  displayName    String?
  createdAt      DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  messages Message[]

  @@unique([channel, channelUserKey])
}

model Message {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  identityId      String    @db.Uuid
  createdAt       DateTime  @default(now())
  clientTimestamp DateTime?
  contentType     String
  text            String?   @db.Text
  rawPayload      String?   @db.Text
  sourceMessageId String
  category        String?
  repliedAt       DateTime?
  replyText       String?   @db.Text

  user     User     @relation(fields: [userId], references: [id])
  identity Identity @relation(fields: [identityId], references: [id])

  @@unique([identityId, sourceMessageId])
  @@index([userId, createdAt])
  @@index([identityId, createdAt])
  @@index([userId, repliedAt])
}

model Summary {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  rangeStart         DateTime
  rangeEnd           DateTime
  createdAt          DateTime @default(now())
  status             String
  summaryText        String?  @db.Text
  modelName          String?
  promptVersion      String?
  inputMessagesCount Int      @default(0)
  inputHash          String?
  error              String?  @db.Text

  user User @relation(fields: [userId], references: [id])

  @@index([userId, rangeStart, rangeEnd])
}

model UserReminder {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  time          String
  frequencyType String
  intervalDays  Int?
  nextFireAt    DateTime
  label         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([nextFireAt, isActive])
  @@index([userId])
}

model UserSettings {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @unique @db.Uuid
  timezone     String    @default("Asia/Kolkata")
  lastNudgedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}
