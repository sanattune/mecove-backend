NGROK_ADMIN_URL=http://localhost:4040
NGROK_TARGET=host.docker.internal:3000
NGROK_AUTHTOKEN=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# LLM (config in src/llm/llm.yaml)
GROQ_API_KEY=

# Consent gate config (YAML path relative to repo root or absolute)
CONSENT_CONFIG_PATH=consent.config.yaml

# MVP access control config (YAML path relative to repo root or absolute)
MVP_ACCESS_CONFIG_PATH=mvp-access.config.yaml

# Encryption at rest — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# REST API — mobile app support
# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# OTP delivery — WhatsApp template (mecove_otp). No SMS fallback (ADR-0005).
# Template names default to the submitted values; override only if Meta names differ.
# WHATSAPP_OTP_TEMPLATE_NAME=mecove_otp
# WHATSAPP_INVITE_TEMPLATE_NAME=mecove_pro_invite
# WHATSAPP_TEMPLATE_LANG=en
# Dev: skip the real WhatsApp send and log the OTP instead.
# OTP_DEV_MODE=false

# Sentry error monitoring
SENTRY_DSN=

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# CORS — comma-separated origins (default: * — restrict in production)
CORS_ALLOWED_ORIGINS=*

# Reply batching
REPLY_BATCH_DEBOUNCE_MS=5000
REPLY_BATCH_MAX_WAIT_MS=15000

# Native WhatsApp typing indicator during batched reply generation
WHATSAPP_TYPING_INDICATOR_ENABLED=false
